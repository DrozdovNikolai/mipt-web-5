              "raw": "{\n  \"categoryId\": \"cf1dd6cb-61e5-4cf4-8187-12735f614c0c\",\n  \"sku\": \"LF-A60-15W-4000K-E27-{{$timestamp}}\",\n  \"name\": \"LED A60 15W E27 4000K\",\n  \"slug\": \"led-a60-15w-e27-4000k-{{$timestamp}}\",\n  \"shortDescription\": \"Яркая LED-лампа для офиса и дома.\",\n  \"description\": \"Лампа общего назначения с нейтральным белым светом.\",\n  \"basePrice\": 1790,\n  \"discountPrice\": 1590,\n  \"stockQty\": 25,\n  \"powerWatts\": 15,\n  \"socketType\": \"E27\",\n  \"colorTemperature\": \"4000K\",\n  \"luminousFlux\": 1450,\n  \"voltage\": \"220-240V\",\n  \"lifetimeHours\": 30000,\n  \"isDimmable\": false,\n  \"isActive\": true,\n  \"images\": [\n    {\n      \"imageUrl\": \"https://example.com/images/led-a60-15w-front.jpg\",\n      \"altText\": \"LED A60 15W E27 4000K\",\n      \"sortOrder\": 0,\n      \"isMain\": true\n    }\n  ],\n  \"attributes\": [\n    {\n      \"attributeName\": \"Угол свечения\",\n      \"attributeValue\": \"220°\",\n      \"sortOrder\": 0\n    },\n    {\n      \"attributeName\": \"Гарантия\",\n      \"attributeValue\": \"24 месяца\",\n      \"sortOrder\": 1\n    }\n  ]\n}",
              "options": {
